.site-header {
  background: linear-gradient(90deg, #ff4d6d, #7b2ff7, #00b4d8);
  color: #ffffff;
  padding: 24px;
  text-align: center;
}

.header-content {
  margin: 0 auto;
  max-width: 1100px;
}

.top-bar {
  align-items: center;
  display: flex;
  gap: 18px;
  justify-content: space-between;
}

.site-header h1 {
  font-size: clamp(2.4rem, 5vw, 4rem);
  line-height: 1;
  margin: 0;
}

.site-header p {
  font-size: 1.1rem;
  margin: 12px 0 0;
}

nav {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  justify-content: center;
  margin-top: 20px;
}

nav a {
  color: #ffffff;
  font-weight: 700;
  padding: 8px 12px;
  text-decoration: none;
}

nav a:hover,
nav a:focus-visible {
  color: #ffd166;
}

.login-box {
  align-items: center;
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  justify-content: center;
}

.google-btn,
.cart-pill,
.user-pill {
  background: #ffffff;
  border: 0;
  border-radius: 6px;
  color: #6b21a8;
  font-weight: 800;
  padding: 10px 14px;
  text-decoration: none;
}

.google-btn {
  cursor: pointer;
  font: inherit;
}

.cart-pill {
  background: #ffd166;
  color: #17202a;
}

main {
  margin: 0 auto;
  max-width: 1120px;
  padding: 28px 18px;
}

.panel {
  background: #ffffff;
  border: 2px solid #f4e8ff;
  border-radius: 8px;
  box-shadow: 0 12px 32px rgba(98, 52, 147, 0.18);
  margin: 0 auto 28px;
  padding: clamp(20px, 4vw, 32px);
}

.panel h2 {
  color: #7b2ff7;
  font-size: clamp(1.8rem, 4vw, 2.5rem);
  line-height: 1.1;
  margin: 0 0 18px;
  text-align: center;
}

.panel p {
  color: #243443;
  font-size: 1.06rem;
  line-height: 1.6;
}

.hero-panel {
  display: grid;
  gap: 24px;
  grid-template-columns: minmax(0, 0.95fr) minmax(320px, 1.2fr);
  overflow: hidden;
}

.hero-copy {
  align-self: center;
}

.hero-copy h2 {
  text-align: left;
}

.eyebrow {
  color: #ff4d6d;
  font-size: 0.85rem;
  font-weight: 800;
  letter-spacing: 0;
  margin: 0 0 8px;
  text-transform: uppercase;
}

.hero-img {
  aspect-ratio: 16 / 10;
  border-radius: 8px;
  height: 100%;
  max-height: 390px;
  min-height: 270px;
  object-fit: cover;
  width: 100%;
}

.button-link,
.contact-form button,
.pay-btn {
  background: linear-gradient(90deg, #ff4d6d, #ff9f1c);
  border: 0;
  border-radius: 6px;
  color: #ffffff;
  cursor: pointer;
  display: inline-flex;
  font: inherit;
  font-weight: 800;
  justify-content: center;
  line-height: 1;
  margin-top: 8px;
  padding: 13px 22px;
  text-decoration: none;
}

.button-link:hover,
.button-link:focus-visible,
.contact-form button:hover,
.contact-form button:focus-visible,
.pay-btn:hover,
.pay-btn:focus-visible {
  background: linear-gradient(90deg, #7b2ff7, #00b4d8);
}

.product-grid {
  display: grid;
  gap: 18px;
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.product-card {
  background: linear-gradient(180deg, #fff7fb, #eefbff);
  border: 1px solid #ffd6e0;
  border-radius: 8px;
  box-shadow: 0 8px 16px rgba(118, 148, 174, 0.16);
  padding: 18px;
}

.product-icon {
  background: #ffffff;
  border-radius: 8px;
  font-size: 2.4rem;
  margin-bottom: 12px;
  padding: 16px;
  text-align: center;
}

.brand-tag {
  background: #7b2ff7;
  border-radius: 4px;
  color: #ffffff;
  display: inline-block;
  font-size: 0.78rem;
  font-weight: 800;
  padding: 5px 9px;
}

.product-card h3 {
  color: #17202a;
  font-size: 1.3rem;
  margin: 0 0 10px;
}

.product-card p {
  margin: 0;
}

.price-row {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-top: 16px;
}

.price-row strong {
  color: #ff4d6d;
  font-size: 1.2rem;
}

.price-row button {
  background: #00b4d8;
  border: 0;
  border-radius: 6px;
  color: #ffffff;
  cursor: pointer;
  font: inherit;
  font-weight: 800;
  padding: 10px 16px;
}

.cart-section {
  background: linear-gradient(135deg, #fff3b0, #ffffff 45%, #d8f3ff);
}

.empty-cart {
  text-align: center;
}

.cart-list {
  display: grid;
  gap: 10px;
}

.cart-item,
.total-box {
  align-items: center;
  background: #ffffff;
  border: 1px solid #ffd6e0;
  border-radius: 8px;
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  justify-content: space-between;
  padding: 14px 16px;
}

.cart-item-name {
  min-width: 0;
  overflow-wrap: anywhere;
}

.cart-item-right {
  align-items: center;
  display: flex;
  gap: 12px;
}

.remove-btn {
  background: #ffe3e9;
  border: 1px solid #ff9fb3;
  border-radius: 6px;
  color: #c81d4f;
  cursor: pointer;
  font: inherit;
  font-size: 0.85rem;
  font-weight: 800;
  padding: 6px 10px;
}

.remove-btn:hover,
.remove-btn:focus-visible {
  background: #ff4d6d;
  color: #ffffff;
}

.total-box {
  background: #17202a;
  color: #ffffff;
  font-size: 1.2rem;
  margin-top: 14px;
}

.pay-btn {
  cursor: pointer;
  font: inherit;
  font-weight: 800;
  margin-top: 16px;
  padding: 13px 22px;
  width: 100%;
}

.pay-btn:disabled {
  cursor: not-allowed;
  opacity: 0.65;
}

.api-note {
  font-size: 0.95rem;
  margin-bottom: 0;
}

.offer-grid {
  display: grid;
  gap: 18px;
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.offer-tag {
  background: #ff9f1c;
}

.toast {
  animation: toast-in 0.25s ease-out;
  background: #17202a;
  border-radius: 8px;
  bottom: 24px;
  box-shadow: 0 12px 28px rgba(0, 0, 0, 0.3);
  color: #ffffff;
  font-weight: 700;
  left: 50%;
  max-width: calc(100vw - 32px);
  padding: 14px 20px;
  position: fixed;
  text-align: center;
  transform: translateX(-50%);
  z-index: 100;
}

@keyframes toast-in {
  from {
    opacity: 0;
    transform: translate(-50%, 12px);
  }
  to {
    opacity: 1;
    transform: translate(-50%, 0);
  }
}

.contact-form {
  display: grid;
  gap: 8px;
}

.contact-form label {
  font-weight: 800;
}

.contact-form input,
.contact-form textarea {
  border: 1px solid #aebdca;
  border-radius: 6px;
  box-sizing: border-box;
  font: inherit;
  padding: 11px 12px;
  width: 100%;
}

.contact-form textarea {
  min-height: 110px;
  resize: vertical;
}

.contact-form button {
  justify-self: start;
}

footer {
  background: linear-gradient(90deg, #00b4d8, #7b2ff7, #ff4d6d);
  color: #ffffff;
  padding: 14px;
  text-align: center;
}

footer p {
  margin: 0;
}

@media (max-width: 820px) {
  .hero-panel,
  .product-grid,
  .offer-grid {
    grid-template-columns: 1fr;
  }

  .top-bar {
    flex-direction: column;
  }

  .hero-copy h2 {
    text-align: center;
  }

  .hero-img {
    min-height: 220px;
  }
}

@media (max-width: 520px) {
  .site-header {
    padding: 20px 12px;
  }

  nav a {
    padding: 7px 8px;
  }

  main {
    padding: 18px 10px;
  }
}
